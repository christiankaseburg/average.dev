{
  "name": "home-api",
  "projectType": "application",
  "sourceRoot": "apps/home-api",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go build -o ../../dist/apps/home-api/main .",
        "cwd": "apps/home-api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go test -v ./...",
        "cwd": "apps/home-api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "golangci-lint run",
        "cwd": "apps/home-api"
      }
    }
  }
}
